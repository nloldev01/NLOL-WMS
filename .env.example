# Django core
SECRET_KEY=your-strong-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Recipe encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
RECIPE_ENCRYPTION_KEY=your-fernet-key-here

# Database (use DATABASE_URL on Render instead of these individual vars)
DB_NAME=nlol_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432
# DATABASE_URL=postgres://user:pass@host/dbname   # set this on Render; overrides above

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
# On Render: CORS_ALLOWED_ORIGINS=https://your-app.onrender.com
